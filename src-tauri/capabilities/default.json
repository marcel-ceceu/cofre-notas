{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissoes padrao: leitura de arquivos em qualquer caminho selecionado pelo usuario",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.anthropic.com/*" }]
    },
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" },
        { "path": "**/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DESKTOP/**" },
        { "path": "$DESKTOP/**/*" }
      ]
    }
  ]
}
