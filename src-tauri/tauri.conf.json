{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cofre de Notas",
  "version": "0.4.0",
  "identifier": "com.marcel.cofre-notas",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cofre de Notas",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/marcel-ceceu/cofre-notas/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5Mjg3ODRCOUNGMUQxNEQKUldSTjBmR2NTM2dvYVE1V09sbEZzL0FoeER0SW9iZkNZaHVnRUdqVUtLaDRJY0VCNmxIOEluNS8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
